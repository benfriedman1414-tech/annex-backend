# ─────────────────────────────────────────────────────────────
# Annex backend configuration. Copy this file to ".env" and fill in.
# ─────────────────────────────────────────────────────────────

# REQUIRED — your Airtable Personal Access Token (starts with "pat...")
# Create one at https://airtable.com/create/tokens
#   Scopes needed: data.records:read, data.records:write
#   Access: add the "Annex" base
AIRTABLE_API_KEY=

# Your Annex base + tables (already filled in for you)
AIRTABLE_BASE_ID=appaa8u2MVRT4obQP
AIRTABLE_RULES_TABLE=Rules
AIRTABLE_ORDERS_TABLE=Orders

# Which Status value marks an order as "not yet processed".
# Blank orders are always processed. New orders from the form usually have no Status.
ORDERS_NEW_STATUS=

# Status the order is set to after a report is produced
ORDERS_DONE_STATUS=Report ready
ORDERS_SENT_STATUS=Report sent

# OPTIONAL — auto-email the report to the customer.
# Leave RESEND_API_KEY blank to skip email (reports are still saved + status updated).
# Get a key at https://resend.com (free tier available).
RESEND_API_KEY=
# The "from" address MUST be on a domain you've verified in Resend.
FROM_EMAIL=Annex <hello@yourdomain.com>
REPLY_TO_EMAIL=

# OPTIONAL — photo intake ("snap a photo of your plans, we read the numbers").
# Set ANTHROPIC_API_KEY to let the backend read dimensions off an uploaded
# plan / floor plan / hand sketch (Anthropic vision). Blank = photo reading off
# (typed/free-text orders still work). Key: https://console.anthropic.com
ANTHROPIC_API_KEY=
VISION_MODEL=claude-opus-4-8
# Status values for the photo-intake lifecycle. These must exist as options on
# the Orders "Status" single-select:
#   New → Reading photo → Needs confirmation → Confirmed → Report ready → Report sent
ORDERS_READING_STATUS=Reading photo
ORDERS_NEEDS_CONFIRMATION_STATUS=Needs confirmation
ORDERS_CONFIRMED_STATUS=Confirmed
# Orders columns the photo step uses (add these to the table):
#   "Plan photo"       — Attachment field (the uploaded image/PDF)
#   "Extraction notes" — Long text (what the model read, per field, with confidence)
ORDERS_PHOTO_FIELD=Plan photo
ORDERS_NOTES_FIELD=Extraction notes

# Where generated reports are written
REPORTS_DIR=./reports

# Watch mode: how often to poll Airtable for new orders (seconds)
POLL_SECONDS=120
